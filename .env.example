NODE_ENV=development
PORT=4000
# For development: relative path is fine
# For production: use absolute path like "file:/var/www/twitch-giveaway-wheel/backend/prisma/prod.db"
DATABASE_URL="file:./prisma/dev.db"
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
TWITCH_REDIRECT_URI=http://localhost:4000/api/auth/callback
SESSION_SECRET=replace_with_a_long_random_secret_at_least_32_chars
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:4000
VITE_API_BASE_URL=http://localhost:4000
VITE_ALLOWED_HOSTS=localhost,127.0.0.1
COOKIE_SECURE=false
EVENTSUB_WS_URL=wss://eventsub.wss.twitch.tv/ws

# Google AdSense Configuration
# Set to "false" to disable ads globally (default: enabled)
VITE_ADSENSE_ENABLED=true
